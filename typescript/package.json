{
  "name": "@ensoul-ai/sdk",
  "version": "0.2.0",
  "description": "Official TypeScript SDK for the Ensoul API",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "license": "Apache-2.0",
  "homepage": "https://ensoul-ai.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/ensoul-ai/ensoul-sdk.git",
    "directory": "typescript"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "msw": "^2.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.6"
  }
}
